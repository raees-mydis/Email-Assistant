# ─── Microsoft Azure (Step 1 of guide) ───────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# The Office 365 email address to read and send from
USER_EMAIL=you@yourdomain.com

# ─── Anthropic Claude API (Step 3 of guide) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Twilio WhatsApp (Step 2 of guide) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here

# Your Twilio WhatsApp number (sandbox: +14155238886, production: your number)
TWILIO_WHATSAPP_NUMBER=+14155238886

# Your personal mobile number that receives the digests
YOUR_WHATSAPP_NUMBER=+447XXXXXXXXX

# ─── Todoist (Step 4 of guide) ────────────────────────────────────────────────
TODOIST_API_TOKEN=your-todoist-token-here
TODOIST_PROJECT_ID=your-project-id-here

# ─── App config ───────────────────────────────────────────────────────────────
PORT=3000

# Digest schedule: comma-separated cron expressions (UK time)
# Defaults: 8am, 12pm, 3pm
DIGEST_TIMES=0 8 * * *,0 12 * * *,0 15 * * *

# Timezone for scheduling
TZ=Europe/London

# Security: only accept WhatsApp messages from this number (your mobile)
ALLOWED_SENDER=+447XXXXXXXXX
